{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "MyCars": "Debug",
      "Npgsql": "Warning"
    }
  },

  "Database": {
    "Provider": "Rest"
  },

  "Ai": {
    "Provider": "Groq",
    "Providers": {
      "Anthropic": {
        "ApiKey": "YOUR_ANTHROPIC_API_KEY",
        "Model": "claude-haiku-4-5-20251001",
        "BaseUrl": "https://api.anthropic.com/v1/messages",
        "MaxTokens": 1024
      },
      "Groq": {
        "ApiKey": "YOUR_GROQ_API_KEY",
        "Model": "llama-3.3-70b-versatile",
        "BaseUrl": "https://api.groq.com/openai/v1/chat/completions",
        "MaxTokens": 1024
      },
      "OpenAI": {
        "ApiKey": "YOUR_OPENAI_API_KEY",
        "Model": "gpt-4o-mini",
        "BaseUrl": "https://api.openai.com/v1/chat/completions",
        "MaxTokens": 1024
      }
    }
  },

  "Supabase": {
    "Url": "https://YOUR_PROJECT.supabase.co",
    "RestBasePath": "/rest/v1",
    "StorageBasePath": "/storage/v1",
    "AnonKey": "YOUR_SUPABASE_ANON_KEY",
    "ServiceRoleKey": "YOUR_SUPABASE_SERVICE_ROLE_KEY",
    "HttpClient": {
      "TimeoutSeconds": 60,
      "RetryCount": 1
    }
  },

  "ConnectionStrings": {
    "SupabaseDb": "Host=db.YOUR_PROJECT.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SslMode=Require"
  },

  "Admin": {
    "CookieName": "mycars_admin",
    "SessionHours": 8
  },
  "SuperAdmin": {
    "Username": "admin",
    "PasswordHash": "GENERATE_WITH: dotnet run -- hash-password YOUR_PASSWORD",
    "CookieName": "mycars_superadmin",
    "SessionHours": 8
  },

  "Vapid": {
    "Subject": "mailto:admin@tuodominio.it",
    "PublicKey":  "GENERATE_WITH: dotnet run -- generate-vapid-keys",
    "PrivateKey": "GENERATE_WITH: dotnet run -- generate-vapid-keys"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "http://localhost:5000"
    ]
  }
}
