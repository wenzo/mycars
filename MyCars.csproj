<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>4aa3e57b-6bd6-4a0a-8c14-7df714efe86f</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <!-- Exclude uploaded files from publish: permissions on the server folder must be set once and preserved -->
    <Content Update="wwwroot\uploads\**">
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </Content>
    <!-- Exclude mobile app folder: Ionic/Capacitor project, not part of the backend -->
    <Content Update="mobile\**">
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="BCrypt.Net-Next" Version="4.2.0" />
    <PackageReference Include="Dapper" Version="2.1.79" />
    <PackageReference Include="Lib.Net.Http.WebPush" Version="3.3.1" />
    <PackageReference Include="Npgsql" Version="10.0.3" />
    <PackageReference Include="Microsoft.OpenApi" Version="2.4.1" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
  </ItemGroup>

</Project>
