{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "MyCars": "Information"
    }
  },
  "AllowedHosts": "*",

  "App": {
    "Name": "MyCars",
    "FrontendMode": "Spa",
    "DefaultLanguage": "it-IT"
  },

  "Database": {
    "Provider": "Rest"
  },

  "Supabase": {
    "Url": "",
    "RestBasePath": "/rest/v1",
    "StorageBasePath": "/storage/v1",
    "AnonKey": "",
    "ServiceRoleKey": "",
    "HttpClient": {
      "TimeoutSeconds": 30,
      "RetryCount": 2
    }
  },

  "ConnectionStrings": {
    "SupabaseDb": ""
  },

  "Jwt": {
    "Issuer": "MyCars",
    "Audience": "MyCars.Client",
    "Key": "",
    "ExpiryMinutes": 1440,
    "RefreshExpiryDays": 30
  },

  "Cors": {
    "AllowedOrigins": []
  },

  "Admin": {
    "CookieName": "mycars_admin",
    "SessionHours": 8
  },
  "SuperAdmin": {
    "Username": "admin",
    "PasswordHash": "",
    "CookieName": "mycars_superadmin",
    "SessionHours": 8
  }
}
